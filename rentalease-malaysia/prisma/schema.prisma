generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER ────────────────────────────────────────────────────────────────────
// The central entity. A user can be a LANDLORD, TENANT, or ADMIN.
// We store the role here so middleware can protect routes accordingly.
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String    // Always stored as bcrypt hash, never plain text
  role          Role      @default(TENANT)
  phone         String?
  icNumber      String?   // Malaysian IC number — sensitive, must be protected under PDPA
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations — a user can own properties (as landlord) or rent them (as tenant)
  ownedProperties    Property[]        @relation("LandlordProperties")
  tenancies          Tenancy[]         @relation("TenantTenancies")
  sentMessages       Message[]         @relation("SentMessages")
  receivedMessages   Message[]         @relation("ReceivedMessages")
  uploadedProofs     PaymentProof[]     @relation("UploadedProofs")
}

enum Role {
  LANDLORD
  TENANT
  ADMIN
}

// ─── PROPERTY ────────────────────────────────────────────────────────────────
// A property belongs to one landlord (User with role LANDLORD).
model Property {
  id          String    @id @default(cuid())
  address     String
  city        String
  state       String
  postcode    String
  type        String    // e.g. "Apartment", "Terrace House", "Condo"
  bedrooms    Int
  bathrooms   Int
  rentAmount  Decimal   @db.Decimal(10, 2)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // A property is owned by one landlord
  landlordId  String
  landlord    User      @relation("LandlordProperties", fields: [landlordId], references: [id])

  // A property can have multiple tenancies over time (but only one active at a time)
  tenancies   Tenancy[]
}

// ─── TENANCY ─────────────────────────────────────────────────────────────────
// The core entity — represents an active or historical rental agreement
// between a landlord (via Property) and a tenant.
model Tenancy {
  id              String         @id @default(cuid())
  startDate       DateTime
  endDate         DateTime
  monthlyRent     Decimal        @db.Decimal(10, 2)
  depositAmount   Decimal        @db.Decimal(10, 2)
  status          TenancyStatus  @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Foreign keys connecting this tenancy to a property and a tenant
  propertyId      String
  property        Property       @relation(fields: [propertyId], references: [id])

  tenantId        String
  tenant          User           @relation("TenantTenancies", fields: [tenantId], references: [id])

  // A tenancy has one agreement document and many rent payments
  agreement       Agreement?
  rentPayments    RentPayment[]
  messages        Message[]
}

enum TenancyStatus {
  PENDING     // Agreement drafted but not yet signed
  ACTIVE      // Currently running tenancy
  EXPIRED     // Past the end date
  TERMINATED  // Ended early
}

// ─── AGREEMENT ───────────────────────────────────────────────────────────────
// The actual tenancy agreement document — generated by AI, stored here.
// One tenancy has exactly one agreement.
model Agreement {
  id                   String          @id @default(cuid())
  rawContent           String          @db.Text
  plainLanguageSummary String          @db.Text
  redFlags             String?         @db.Text
  negotiationNotes     String?         @db.Text  // Tenant's feedback when requesting changes
  status               AgreementStatus @default(DRAFT)
  fileUrl              String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  tenancyId            String          @unique
  tenancy              Tenancy         @relation(fields: [tenancyId], references: [id])
}

enum AgreementStatus {
  DRAFT       // AI generated, landlord hasn't confirmed yet
  FINALIZED   // Landlord reviewed and confirmed — awaiting tenant review
  NEGOTIATING // Tenant requested changes — landlord needs to revise
  SIGNED      // Tenant accepted — both parties have agreed
}

// ─── RENT PAYMENT ────────────────────────────────────────────────────────────
// Tracks each monthly rent payment for a tenancy.
model RentPayment {
  id              String        @id @default(cuid())
  dueDate         DateTime
  paidDate        DateTime?
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus @default(PENDING)
  notes           String?
  rejectionReason String?       @db.Text  // Landlord's reason when rejecting proof
  createdAt       DateTime      @default(now())

  tenancyId       String
  tenancy         Tenancy       @relation(fields: [tenancyId], references: [id])

  // One payment can have multiple proof photos
  proofs          PaymentProof[]
}

enum PaymentStatus {
  PENDING       // Payment is due but no proof uploaded yet
  UNDER_REVIEW  // Tenant uploaded proof, awaiting landlord verification
  PAID          // Landlord approved the proof
  LATE          // Past due date with no proof uploaded
  WAIVED        // Landlord waived this payment
}

// ─── PAYMENT PROOF ───────────────────────────────────────────────────────────
// Stores Cloudinary URLs for each proof photo uploaded by a tenant.
// One RentPayment can have multiple proofs (e.g. receipt + bank screenshot).
model PaymentProof {
  id              String    @id @default(cuid())
  imageUrl        String    // Full Cloudinary CDN URL
  publicId        String    // Cloudinary public ID — needed for deletion
  isReadByTenant  Boolean   @default(false) // Tracks if tenant saw landlord's decision
  createdAt       DateTime  @default(now())

  paymentId       String
  payment         RentPayment @relation(fields: [paymentId], references: [id])

  uploadedById    String    // The tenant who uploaded this proof
  uploadedBy      User      @relation("UploadedProofs", fields: [uploadedById], references: [id])
}

// ─── MESSAGE ─────────────────────────────────────────────────────────────────
// In-platform messaging between landlord and tenant, scoped to a tenancy.
model Message {
  id          String    @id @default(cuid())
  content     String    @db.Text
  read        Boolean   @default(false)
  createdAt   DateTime  @default(now())

  tenancyId   String
  tenancy     Tenancy   @relation(fields: [tenancyId], references: [id])

  senderId    String
  sender      User      @relation("SentMessages", fields: [senderId], references: [id])

  receiverId  String
  receiver    User      @relation("ReceivedMessages", fields: [receiverId], references: [id])
}