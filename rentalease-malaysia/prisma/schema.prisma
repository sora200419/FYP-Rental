generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER ────────────────────────────────────────────────────────────────────
// The central entity. A user can be a LANDLORD, TENANT, or ADMIN.
// We store the role here so middleware can protect routes accordingly.
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String    // Always stored as bcrypt hash, never plain text
  role          Role      @default(TENANT)
  phone         String?
  icNumber      String?   // Malaysian IC number — sensitive, must be protected under PDPA
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations — a user can own properties (as landlord) or rent them (as tenant)
  ownedProperties    Property[]        @relation("LandlordProperties")
  tenancies          Tenancy[]         @relation("TenantTenancies")
  sentMessages       Message[]         @relation("SentMessages")
  receivedMessages   Message[]         @relation("ReceivedMessages")
}

enum Role {
  LANDLORD
  TENANT
  ADMIN
}

// ─── PROPERTY ────────────────────────────────────────────────────────────────
// A property belongs to one landlord (User with role LANDLORD).
model Property {
  id          String    @id @default(cuid())
  address     String
  city        String
  state       String
  postcode    String
  type        String    // e.g. "Apartment", "Terrace House", "Condo"
  bedrooms    Int
  bathrooms   Int
  rentAmount  Decimal   @db.Decimal(10, 2)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // A property is owned by one landlord
  landlordId  String
  landlord    User      @relation("LandlordProperties", fields: [landlordId], references: [id])

  // A property can have multiple tenancies over time (but only one active at a time)
  tenancies   Tenancy[]
}

// ─── TENANCY ─────────────────────────────────────────────────────────────────
// The core entity — represents an active or historical rental agreement
// between a landlord (via Property) and a tenant.
model Tenancy {
  id              String         @id @default(cuid())
  startDate       DateTime
  endDate         DateTime
  monthlyRent     Decimal        @db.Decimal(10, 2)
  depositAmount   Decimal        @db.Decimal(10, 2)
  status          TenancyStatus  @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Foreign keys connecting this tenancy to a property and a tenant
  propertyId      String
  property        Property       @relation(fields: [propertyId], references: [id])

  tenantId        String
  tenant          User           @relation("TenantTenancies", fields: [tenantId], references: [id])

  // A tenancy has one agreement document and many rent payments
  agreement       Agreement?
  rentPayments    RentPayment[]
  messages        Message[]
}

enum TenancyStatus {
  PENDING     // Agreement drafted but not yet signed
  ACTIVE      // Currently running tenancy
  EXPIRED     // Past the end date
  TERMINATED  // Ended early
}

// ─── AGREEMENT ───────────────────────────────────────────────────────────────
// The actual tenancy agreement document — generated by AI, stored here.
// One tenancy has exactly one agreement.
model Agreement {
  id                String    @id @default(cuid())
  rawContent        String    @db.Text  // Full agreement text generated by Gemini API
  plainLanguageSummary String @db.Text  // Plain-language explanation of each clause
  redFlags          String?   @db.Text  // JSON array of AI-detected red flags
  status            AgreementStatus @default(DRAFT)
  fileUrl           String?           // URL to stored PDF after signing
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // One-to-one with Tenancy
  tenancyId         String    @unique
  tenancy           Tenancy   @relation(fields: [tenancyId], references: [id])
}

enum AgreementStatus {
  DRAFT       // AI generated, user hasn't confirmed yet
  FINALIZED   // User reviewed and confirmed
  SIGNED      // Both parties have signed
}

// ─── RENT PAYMENT ────────────────────────────────────────────────────────────
// Tracks each monthly rent payment for a tenancy.
model RentPayment {
  id          String        @id @default(cuid())
  dueDate     DateTime
  paidDate    DateTime?     // null means not yet paid
  amount      Decimal       @db.Decimal(10, 2)
  status      PaymentStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now())

  tenancyId   String
  tenancy     Tenancy       @relation(fields: [tenancyId], references: [id])
}

enum PaymentStatus {
  PENDING
  PAID
  LATE
  WAIVED
}

// ─── MESSAGE ─────────────────────────────────────────────────────────────────
// In-platform messaging between landlord and tenant, scoped to a tenancy.
model Message {
  id          String    @id @default(cuid())
  content     String    @db.Text
  read        Boolean   @default(false)
  createdAt   DateTime  @default(now())

  tenancyId   String
  tenancy     Tenancy   @relation(fields: [tenancyId], references: [id])

  senderId    String
  sender      User      @relation("SentMessages", fields: [senderId], references: [id])

  receiverId  String
  receiver    User      @relation("ReceivedMessages", fields: [receiverId], references: [id])
}